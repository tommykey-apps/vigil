{
	"name": "web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"db:up": "docker compose -f ../docker-compose.yml up -d dynamodb-local",
		"db:down": "docker compose -f ../docker-compose.yml down",
		"db:init": "../scripts/init-dynamodb-local.sh"
	},
	"devDependencies": {
		"@fontsource-variable/figtree": "^5.2.10",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^25.6.0",
		"bits-ui": "^2.18.0",
		"clsx": "^2.1.1",
		"jsdom": "^29.1.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.4",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"@aws-sdk/client-dynamodb": "^3.1038.0",
		"@aws-sdk/lib-dynamodb": "^3.1038.0"
	}
}
